{
  "name": "wally",
  "version": "2.0.0",
  "private": true,
  "description": "Wally 2.0 — gestão financeira pessoal e divisão de despesas em grupo (monorepo)",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.9.6",
    "turbo": "^2.10.6",
    "typescript": "^5.8.3"
  }
}
