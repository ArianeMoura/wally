{
  "name": "@wally/api",
  "version": "2.0.0",
  "description": "Wally 2.0 — API (Fastify + Drizzle ORM + PostgreSQL)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:check": "drizzle-kit check",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/jwt": "^9.0.4",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^5.2.2",
    "@wally/contracts": "workspace:*",
    "@wally/core": "workspace:*",
    "argon2": "^0.45.1",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@rocketseat/eslint-config": "^2.2.2",
    "@types/node": "^22.15.9",
    "@types/pg": "^8.11.11",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@wally/config": "workspace:*",
    "drizzle-kit": "^0.30.2",
    "eslint": "^8.52.0",
    "globals": "^16.1.0",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0",
    "vitest": "^2.1.8"
  }
}
