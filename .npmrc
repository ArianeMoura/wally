# pnpm — política de dependências do monorepo Wally.
# Pacotes internos (@wally/*) resolvidos via workspace protocol.
link-workspace-packages=true
prefer-workspace-packages=true

# node-linker=hoisted: obrigatório para compatibilidade com React Native /
# Metro (Expo SDK 52), que não lida bem com o node_modules isolado do pnpm.
node-linker=hoisted
