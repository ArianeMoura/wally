# Ambiente
NODE_ENV=development
HOST=0.0.0.0
PORT=3333

# Banco (o docker-compose sobe o Postgres em localhost:5432)
DATABASE_URL=postgres://wally:wally@localhost:5432/wally

# Segredos JWT — ≥ 32 caracteres, únicos por ambiente.
# Gere com: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d

# CORS: origem(ns) separadas por vírgula. Use '*' apenas em desenvolvimento.
CORS_ORIGIN=*
